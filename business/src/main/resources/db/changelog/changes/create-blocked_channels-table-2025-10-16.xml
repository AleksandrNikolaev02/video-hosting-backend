<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="create-blocked_channels-table" author="alex">
        <createTable tableName="blocked_channels">
            <column name="id" type="java.lang.Long">
                <constraints primaryKey="true" unique="true" nullable="false"/>
            </column>
            <column name="message" type="java.lang.String"/>
            <column name="time_block" type="date"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="blocked_channels" baseColumnNames="id"
                                 constraintName="fk_blocked_channels_to_channels"
                                 referencedTableName="channels"
                                 referencedColumnNames="id"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="blocked_channels"
                                      constraintName="fk_blocked_channels_to_channels"/>
            <dropColumn tableName="blocked_channels"/>
        </rollback>
    </changeSet>

</databaseChangeLog>