<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="create-videos-table" author="alex">
        <createTable tableName="videos">
            <column name="id" type="java.lang.Long">
                <constraints primaryKey="true" unique="true" nullable="false"/>
            </column>

            <column name="user_id" type="java.lang.Long"/>
            <column name="description" type="java.lang.String"/>
            <column name="name" type="java.lang.String"/>
            <column name="path" type="java.lang.String"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="videos" baseColumnNames="user_id" constraintName="fk_videos"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>
    <rollback>
        <dropForeignKeyConstraint baseTableName="videos"/>
        <dropTable tableName="videos"/>
    </rollback>

    </changeSet>
</databaseChangeLog>