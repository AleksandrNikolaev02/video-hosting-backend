<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="add-primary-key-to-table-comments" author="alex">
        <addPrimaryKey tableName="comments" columnNames="id" constraintName="comments_pkey"/>

        <rollback>
            <dropPrimaryKey tableName="comments" constraintName="comments_pkey"/>
        </rollback>
    </changeSet>

</databaseChangeLog>