<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="create-channels-table" author="alex">
        <createTable tableName="channels">
            <column name="id" type="java.lang.Long">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>

            <column name="name" type="java.lang.String">
                <constraints unique="true"/>
            </column>

            <column name="description" type="java.lang.String"/>

            <column name="created_at" type="date"/>
            <column name="author_id" type="java.lang.Long"/>
            <column name="count_subs" type="java.lang.Integer"/>
        </createTable>
    </changeSet>

</databaseChangeLog>