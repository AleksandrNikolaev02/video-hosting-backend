<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">
    <changeSet id="add-unique-constraint-to-viewing-table" author="alex">
        <addUniqueConstraint tableName="viewings" columnNames="user_id" constraintName="user_unique"/>

        <rollback>
            <dropUniqueConstraint tableName="viewings" constraintName="user_unique"/>
        </rollback>
    </changeSet>

</databaseChangeLog>