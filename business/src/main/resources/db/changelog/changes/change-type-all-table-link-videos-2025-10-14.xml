<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="change-type-all-table-link-videos" author="alex">
        <dropColumn tableName="previews" columnName="video_id"/>
        <dropColumn tableName="reactions" columnName="video_id"/>
        <dropColumn tableName="viewings" columnName="video_id"/>
        <dropColumn tableName="videos_tags" columnName="video_id"/>

        <addColumn tableName="previews">
            <column name="video_id" type="uuid"/>
        </addColumn>

        <addColumn tableName="reactions">
            <column name="video_id" type="uuid"/>
        </addColumn>

        <addColumn tableName="viewings">
            <column name="video_id" type="uuid"/>
        </addColumn>

        <addColumn tableName="videos_tags">
            <column name="video_id" type="uuid"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>