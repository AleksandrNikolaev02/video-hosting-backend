<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="add-column-status-in-channels-table" author="alex">
        <addColumn tableName="channels">
            <column name="status" type="java.lang.String"/>
        </addColumn>

        <addColumn tableName="playlists">
            <column name="status" type="java.lang.String"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="channels" columnName="status"/>
            <dropColumn tableName="playlists" columnName="status"/>
        </rollback>
    </changeSet>

</databaseChangeLog>