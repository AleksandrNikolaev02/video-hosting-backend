<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="add-foreign-key-constraint" author="alex">
        <addColumn tableName="videos">
            <column name="playlist_id" type="java.lang.Long"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="videos" baseColumnNames="playlist_id"
                                 constraintName="fk_videos_playlists"
                                 referencedTableName="playlists"
                                 referencedColumnNames="id"/>

        <rollback>
            <dropColumn tableName="videos" columnName="playlist_id"/>
            <dropForeignKeyConstraint baseTableName="videos" constraintName="fk_videos_playlists"/>
        </rollback>
    </changeSet>

</databaseChangeLog>