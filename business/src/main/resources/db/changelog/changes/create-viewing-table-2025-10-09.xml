<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">
    <changeSet id="create-viewing-table" author="alex">
        <createTable tableName="viewings">
            <column name="id" type="java.lang.Long">
                <constraints primaryKey="true" unique="true" nullable="false"/>
            </column>
            <column name="user_id" type="java.lang.Long"/>
            <column name="ip" type="java.lang.String"/>
            <column name="user_agent" type="java.lang.String"/>
            <column name="video_id" type="java.lang.Long"/>
        </createTable>

        <addUniqueConstraint tableName="viewings" columnNames="user_agent, ip" constraintName="unique_id"/>

        <rollback>
            <dropTable tableName="viewings"/>
            <dropUniqueConstraint tableName="viewings" constraintName="unique_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>