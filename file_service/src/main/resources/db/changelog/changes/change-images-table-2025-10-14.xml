<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="change-images-table" author="alex">
        <dropPrimaryKey tableName="images" constraintName="images_pkey"/>

        <dropColumn tableName="images" columnName="id"/>

        <modifyDataType tableName="images" columnName="filename" newDataType="uuid"/>

        <addPrimaryKey tableName="images" columnNames="filename"/>

        <addUniqueConstraint tableName="images" columnNames="filename"/>
    </changeSet>

</databaseChangeLog>