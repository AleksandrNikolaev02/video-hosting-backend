<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="create-files-table" author="alex">
        <createTable tableName="files">
            <column name="id" type="java.lang.Long">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="java.lang.Long"/>
            <column name="filename" type="java.lang.String"/>
            <column name="filename_orig" type="java.lang.String"/>
            <column name="content_type" type="java.lang.String"/>
            <column name="key" type="java.lang.String"/>
            <column name="length" type="java.lang.Long"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="files"/>
        </rollback>
    </changeSet>

</databaseChangeLog>