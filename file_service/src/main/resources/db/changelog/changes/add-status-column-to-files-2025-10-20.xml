<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="add-status-column-to-files" author="alex">
        <addColumn tableName="files">
            <column name="status" type="java.lang.String"/>
        </addColumn>

        <addColumn tableName="images">
            <column name="status" type="java.lang.String"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="images" columnName="status"/>
            <dropColumn tableName="files" columnName="status"/>
        </rollback>
    </changeSet>
    
</databaseChangeLog>